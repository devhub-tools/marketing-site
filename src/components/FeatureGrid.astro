---

---

<section class="px-6 max-w-7xl mx-auto" id="features">
  <div>
    <p class="text-6xl font-medium border-b border-gray-900 pb-6">
      Everything you need for secure<br />production queries
    </p>

    <div class="grid grid-cols-3 gap-6 mt-18">
      <div class="bg-surface-1 rounded-3xl col-span-2 p-12 flex flex-col gap-8">
        <div
          class="h-64 bg-white rounded-xl border border-gray-200 overflow-hidden flex flex-col"
        >
          <div
            class="bg-surface-3 px-4 py-3 border-b border-surface-2 flex items-center justify-between"
          >
            <div class="flex items-center gap-2">
              <svg
                class="w-5 h-5 text-gray-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"
                ></path></svg
              >
              <span class="font-medium text-gray-700 text-sm">public.users</span
              >
            </div>
            <div class="flex gap-2">
              <div
                class="text-xs font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded-md flex items-center gap-1 border border-blue-100"
              >
                <svg
                  class="w-3 h-3"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  ></path></svg
                >
                PII Protected
              </div>
            </div>
          </div>
          <div class="overflow-hidden flex-1 p-4 bg-white">
            <table
              class="w-full text-left text-sm text-gray-600 whitespace-nowrap"
            >
              <thead
                class="text-xs text-gray-400 uppercase tracking-wider border-b border-surface-2"
              >
                <tr>
                  <th class="pb-3 font-medium px-2">id</th>
                  <th class="pb-3 font-medium px-2">name</th>
                  <th class="pb-3 font-medium px-2">email</th>
                  <th class="pb-3 font-medium px-2">role</th>
                  <th class="pb-3 font-medium px-2">created_at</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-2">
                <tr class="hover:bg-surface-3/50 transition-colors">
                  <td class="py-3 px-2 font-mono text-xs text-gray-500">1</td>
                  <td class="py-3 px-2"
                    ><span
                      class="bg-gray-100 flex items-center w-max px-1.5 py-0.5 rounded text-gray-500 font-mono tracking-widest"
                      >***</span
                    ></td
                  >
                  <td class="py-3 px-2"
                    ><span
                      class="bg-gray-100 flex items-center w-max px-1.5 py-0.5 rounded text-gray-500 font-mono tracking-widest"
                      >***</span
                    ></td
                  >
                  <td class="py-3 px-2"
                    ><span class="text-xs font-medium">admin</span></td
                  >
                  <td class="py-3 px-2 font-mono text-xs text-gray-400"
                    >2026-03-10</td
                  >
                </tr>
                <tr class="hover:bg-surface-3/50 transition-colors">
                  <td class="py-3 px-2 font-mono text-xs text-gray-500">2</td>
                  <td class="py-3 px-2"
                    ><span
                      class="bg-gray-100 flex items-center w-max px-1.5 py-0.5 rounded text-gray-500 font-mono tracking-widest"
                      >***</span
                    ></td
                  >
                  <td class="py-3 px-2"
                    ><span
                      class="bg-gray-100 flex items-center w-max px-1.5 py-0.5 rounded text-gray-500 font-mono tracking-widest"
                      >***</span
                    ></td
                  >
                  <td class="py-3 px-2"
                    ><span class="text-xs font-medium">user</span></td
                  >
                  <td class="py-3 px-2 font-mono text-xs text-gray-400"
                    >2026-03-11</td
                  >
                </tr>
                <tr class="hover:bg-surface-3/50 transition-colors">
                  <td class="py-3 px-2 font-mono text-xs text-gray-500">3</td>
                  <td class="py-3 px-2"
                    ><span
                      class="bg-gray-100 flex items-center w-max px-1.5 py-0.5 rounded text-gray-500 font-mono tracking-widest"
                      >***</span
                    ></td
                  >
                  <td class="py-3 px-2"
                    ><span
                      class="bg-gray-100 flex items-center w-max px-1.5 py-0.5 rounded text-gray-500 font-mono tracking-widest"
                      >***</span
                    ></td
                  >
                  <td class="py-3 px-2"
                    ><span class="text-xs font-medium">user</span></td
                  >
                  <td class="py-3 px-2 font-mono text-xs text-gray-400"
                    >2026-03-12</td
                  >
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="flex flex-col gap-3">
          <h3 class="text-3xl font-semibold">Protect PII on demand</h3>
          <p class="text-xl">
            QueryDesk lets you hide PII with smart rules by rewriting queries on
            the fly. Ensuring no sensitive data leaves your database.
          </p>
        </div>
        <button
          class="text-xl w-fit rounded-full border border-blue-300 text-blue-300 px-6 py-3"
        >
          See it in action
        </button>
      </div>

      <div class="bg-surface-1 rounded-3xl p-12">
        <div class="flex flex-col gap-6">
          <h3 class="text-3xl font-semibold">Approval flow for queries</h3>
          <p class="text-xl">
            We integrate natively with Slack/Teams to let your team get quick
            access to production data, without leaving the tools you know.
          </p>
          <button
            class="text-xl w-fit rounded-full border border-blue-300 text-blue-300 px-6 py-3"
          >
            See it in action
          </button>
        </div>
      </div>

      <!-- Bottom Row: 3 items -->
      <div class="bg-surface-1 rounded-3xl p-12">
        <div class="flex flex-col gap-6">
          <h3 class="text-3xl font-semibold">SOC2/HIPAA expert*</h3>
          <p class="text-xl">
            *Actually we don't have this, any more we are currently too small
            but we will have it. Let us know if this is a hard requirement for
            you.
          </p>

          <button
            class="text-xl w-fit rounded-full border border-blue-300 text-blue-300 px-6 py-3"
          >
            See it in action
          </button>
        </div>
      </div>

      <div class="bg-surface-1 rounded-3xl p-12">
        <div class="flex flex-col gap-6">
          <h3 class="text-3xl font-semibold">Multi-DB Support</h3>
          <p class="text-xl">
            PostgreSQL, MongoDB, BigQuery, and whatever else you're stuck with.
          </p>

          <button
            class="text-xl w-fit rounded-full border border-blue-300 text-blue-300 px-6 py-3"
          >
            See it in action
          </button>
        </div>
      </div>

      <div class="bg-surface-1 rounded-3xl p-12">
        <div class="flex flex-col gap-6">
          <h3 class="text-3xl font-semibold">Audit who, to what, and how</h3>
          <p class="text-xl">
            Access logs built-in. Easily see which developer accessed what
            database and what queries they run, export nicely formatted PDFs to
            impress.
          </p>

          <button
            class="text-xl w-fit rounded-full border border-blue-300 text-blue-300 px-6 py-3"
          >
            See it in action
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
